{
  "name": "@qualcomm-ui/vite",
  "version": "1.1.2",
  "description": "Vite build utilities for library mode",
  "license": "BSD-3-Clause-Clear",
  "author": "Ryan Bower",
  "repository": "https://github.com/qualcomm/qualcomm-ui-utils",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "run-s clean build:js build:types",
    "clean": "shx rm -rf dist node_modules/.tmp",
    "build:js": "vite build",
    "build:types": "tsc -p tsconfig.lib.json",
    "dev": "run-p watch:js watch:types",
    "watch:js": "vite build --watch",
    "watch:types": "tsc -b tsconfig.lib.json -w --preserveWatchOutput --force",
    "lint": "eslint --quiet",
    "test": "vitest --run",
    "prepublishOnly": "qui-cli pre-publish",
    "postpublish": "qui-cli post-publish"
  },
  "dependencies": {
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "@qualcomm-ui/cli": "workspace:^1.0.8",
    "@qualcomm-ui/tsconfig": "workspace:^2.2.0",
    "npm-run-all2": "^8.0.4",
    "shx": "^0.4.0",
    "tsx": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "vite": ">=8.0.0"
  }
}
