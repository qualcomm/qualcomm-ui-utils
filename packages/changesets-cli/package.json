{
  "name": "@qualcomm-ui/changesets-cli",
  "version": "1.2.1",
  "description": "Changeset automation CLI for conventional commits",
  "author": "Ryan Bower",
  "license": "BSD-3-Clause-Clear",
  "repository": "https://github.com/qualcomm/qualcomm-ui-utils",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "qui-changesets": "./lib/cli.cjs"
  },
  "files": [
    "dist",
    "lib"
  ],
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "run-s clean compile",
    "clean": "shx rm -rf dist",
    "compile": "run-p compile:cli compile:types",
    "compile:cli": "vite build",
    "compile:types": "tsc -b tsconfig.lib.json --force",
    "dev": "run-p watch:cli watch:types",
    "watch:cli": "vite build -w",
    "watch:types": "tsc -b tsconfig.lib.json -w --preserveWatchOutput --force",
    "test": "vitest -c vitest.config.ts --run",
    "lint": "eslint --quiet",
    "prepublishOnly": "qui-cli pre-publish",
    "postpublish": "qui-cli post-publish"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@manypkg/get-packages": "^3.1.0",
    "@octokit/rest": "^22.0.1",
    "ts-morph": "^25.0.1"
  },
  "devDependencies": {
    "@changesets/read": "^0.6.6",
    "@changesets/types": "^6.1.0",
    "@changesets/write": "^0.4.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@qualcomm-ui/cli": "workspace:*",
    "@qualcomm-ui/vite": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dayjs": "^1.11.19",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
